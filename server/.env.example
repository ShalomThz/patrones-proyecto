# Copia este archivo como .env y ajusta los valores
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/gestion_notificaciones
CLIENT_URL=http://localhost:5173

# Correo real (canal "correo"). Sin RESEND_API_KEY el envio se simula.
RESEND_API_KEY=tu_api_key_de_resend
# Remitente. Debe ser un dominio verificado en Resend; el de pruebas funciona
# pero solo entrega al correo de tu propia cuenta de Resend.
RESEND_FROM=Académico <onboarding@resend.dev>